{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "paths": {
      "@beonedge/design-tokens": ["./packages/design-tokens/src/index.ts"],
      "@beonedge/design-tokens/*": ["./packages/design-tokens/src/*"],
      "@beonedge/ui-kits": ["./packages/ui-kits/src/index.ts"],
      "@beonedge/ui-kits/*": ["./packages/ui-kits/src/*"],
      "@beonedge/shared": ["./packages/shared/src/index.ts"],
      "@beonedge/shared/*": ["./packages/shared/src/*"],
      "@beonedge/client": ["./packages/client/src/index.ts"],
      "@beonedge/client/*": ["./packages/client/src/*"],
      "@beonedge/admin": ["./packages/admin/src/index.ts"],
      "@beonedge/admin/*": ["./packages/admin/src/*"]
    },
    "resolveJsonModule": true,
    "allowJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "app/src",
    "packages/admin/src",
    "packages/client/src",
    "packages/shared/src",
    "packages/ui-kits/src",
    "packages/design-tokens/src",
    "types"
  ],
  "exclude": ["node_modules", "**/dist", "**/build", "packages/landing_page"]
}
