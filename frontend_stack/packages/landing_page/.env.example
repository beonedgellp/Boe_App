# ── Backend (server-side only — NOT exposed to the browser) ─────────────────
# The lead-capture form posts to the same-origin path /api/onboarding/*, which
# next.config.mjs rewrites to {BEO_API_BASE}/v1/onboarding/* server-side.
# This keeps the backend unchanged and avoids any browser CORS dependency.
BEO_API_BASE=http://127.0.0.1:47502

# ── Client app host (browser-exposed) ───────────────────────────────────────
# Base URL of the existing Vite client app that owns the learner-account auth
# flow. The landing page "Sign in" link points at {APP_BASE}/app/login.
NEXT_PUBLIC_BEO_APP_BASE=http://127.0.0.1:5173
