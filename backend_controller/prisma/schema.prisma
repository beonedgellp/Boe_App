// BeOnEdge Prisma Schema — derived from SQL migrations 001-008.
// Run `npx prisma migrate dev` to apply, `npx prisma generate` to regenerate client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  client
  admin
  operations
  support
  system
}

enum UserStatus {
  draft
  pending_review
  kyc_pending
  approved
  rejected
  suspended
  closed
}

enum ReviewStatus {
  not_started
  pending
  in_review
  approved
  rejected
  needs_more_information
}

enum RiskCategory {
  conservative
  balanced
  growth
  aggressive
}


enum ProductStatus {
  draft
  review_pending
  published
  coming_soon
  paused_for_investment
  archived
}

enum ProductRiskLevel {
  low
  moderate
  high
  very_high
}

enum InvestmentPlanType {
  sip
  one_time
}

enum InvestmentPlanStatus {
  draft
  submitted
  pending_first_payment
  first_payment_failed
  pending_mandate_setup
  mandate_pending_user_auth
  active
  installment_due
  installment_processing
  installment_success
  installment_failed
  skip_requested
  paused
  step_up_scheduled
  change_requested
  cancel_requested
  cancelled
  matured
  withdrawal_requested
  closed
}

enum TransactionType {
  sip_installment
  one_time_investment
  redemption
  fee
  adjustment
  refund
}


enum TransactionStatus {
  draft
  submitted
  payment_pending
  payment_failed
  payment_confirmed
  allotted
  cancelled
  reversed
}

enum PaymentStatus {
  created
  gateway_initiated
  pending
  success
  failed
  expired
  refunded
  reconciled
}

enum MandateStatus {
  not_required
  setup_required
  created
  pending_user_auth
  active
  paused
  revoked
  failed
  expired
}

enum StatementStatus {
  queued
  generated
  failed
  voided
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName         String      @map("first_name")
  lastName          String      @map("last_name")
  email             String      @unique
  phone             String?     @unique
  username          String?     @unique
  passwordHash      String?     @map("password_hash")
  role              UserRole    @default(client)
  status            UserStatus  @default(draft)
  riskProfileStatus ReviewStatus @default(not_started) @map("risk_profile_status")
  kycStatus         ReviewStatus @default(not_started) @map("kyc_status")
  approvedAt        DateTime?   @map("approved_at") @db.Timestamptz
  rejectedAt        DateTime?   @map("rejected_at") @db.Timestamptz
  suspendedAt       DateTime?   @map("suspended_at") @db.Timestamptz
  closedAt          DateTime?   @map("closed_at") @db.Timestamptz
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz


  // Relations
  deviceSessions     DeviceSession[]
  kycProfile         KycProfile?
  riskProfile        RiskProfile?
  investmentPlans    InvestmentPlan[]
  transactions       Transaction[]
  payments           Payment[]
  mandates           Mandate[]
  supportTickets     SupportTicket[]
  notifications      Notification[]
  orders             Order[]
  sipControlRequests SipControlRequest[]
  redemptionRequests RedemptionRequest[]
  portfolioSnapshots PortfolioSnapshot[]
  statements         Statement[]
  adminAuditLogs     AdminAuditLog[]     @relation("AuditAdmin")
  timelineEvents     TimelineEvent[]

  @@map("users")
}

model DeviceSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceId         String    @map("device_id")
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  pushToken        String?   @map("push_token")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_sessions")
}


model KycProfile {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String       @unique @map("user_id") @db.Uuid
  panNumberEncrypted  String?      @map("pan_number_encrypted")
  panLast4            String?      @map("pan_last4")
  aadhaarLast4        String?      @map("aadhaar_last4")
  addressJson         Json         @default("{}") @map("address_json")
  documentRefsJson    Json         @default("[]") @map("document_refs_json")
  reviewStatus        ReviewStatus @default(not_started) @map("review_status")
  adminNotes          String?      @map("admin_notes")
  reviewedBy          String?      @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?    @map("reviewed_at") @db.Timestamptz
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_profiles")
}

model RiskProfile {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String       @unique @map("user_id") @db.Uuid
  ageBand              String       @map("age_band")
  investmentHorizon    String       @map("investment_horizon")
  incomeBand           String       @map("income_band")
  lossTolerance        String       @map("loss_tolerance")
  investmentExperience String       @map("investment_experience")
  riskScore            Int          @map("risk_score")
  riskCategory         RiskCategory @map("risk_category")
  answersJson          Json         @default("{}") @map("answers_json")
  completedAt          DateTime     @default(now()) @map("completed_at") @db.Timestamptz
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("risk_profiles")
}


model Product {
  id                             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                           String
  slug                           String        @unique
  category                       String
  status                         ProductStatus @default(draft)
  riskLevel                      ProductRiskLevel @map("risk_level")
  objective                      String
  minimumSipAmount               Decimal       @map("minimum_sip_amount") @db.Decimal(18, 2)
  minimumLumpsumAmount           Decimal       @map("minimum_lumpsum_amount") @db.Decimal(18, 2)
  minimumDurationMonths          Int?          @map("minimum_duration_months")
  recommendedHoldingPeriodMonths Int?          @map("recommended_holding_period_months")
  lockInText                     String?       @map("lock_in_text")
  feeText                        String?       @map("fee_text")
  currentDisclosureId            String?       @map("current_disclosure_id") @db.Uuid
  publishedAt                    DateTime?     @map("published_at") @db.Timestamptz
  archivedAt                     DateTime?     @map("archived_at") @db.Timestamptz
  createdAt                      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  disclosures     ProductDisclosure[]
  holdings        ProductHolding[]
  investmentPlans InvestmentPlan[]
  transactions    Transaction[]

  @@map("products")
}

model ProductDisclosure {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  version      Int
  title        String
  body         String
  effectiveFrom DateTime @map("effective_from") @db.Timestamptz
  publishedBy  String?  @map("published_by") @db.Uuid
  publishedAt  DateTime @default(now()) @map("published_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, version])
  @@map("product_disclosures")
}


model ProductHolding {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  symbol          String?
  companyName     String?  @map("company_name")
  sector          String?
  assetClass      String   @map("asset_class")
  allocationPercent Decimal @map("allocation_percent") @db.Decimal(7, 4)
  asOfDate        DateTime @map("as_of_date") @db.Date
  source          String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_holdings")
}

model InvestmentPlan {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String              @map("user_id") @db.Uuid
  productId      String              @map("product_id") @db.Uuid
  type           InvestmentPlanType
  amount         Decimal             @db.Decimal(18, 2)
  durationMonths Int?                @map("duration_months")
  debitDay       Int?                @map("debit_day")
  status         InvestmentPlanStatus @default(draft)
  mandateId      String?             @map("mandate_id") @db.Uuid
  startDate      DateTime?           @map("start_date") @db.Date
  nextDueDate    DateTime?           @map("next_due_date") @db.Date
  completedAt    DateTime?           @map("completed_at") @db.Timestamptz
  cancelledAt    DateTime?           @map("cancelled_at") @db.Timestamptz
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  transactions Transaction[]
  orders       Order[]

  @@map("investment_plans")
}


model Transaction {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  productId        String            @map("product_id") @db.Uuid
  investmentPlanId String?           @map("investment_plan_id") @db.Uuid
  type             TransactionType
  amount           Decimal           @db.Decimal(18, 2)
  nav              Decimal?          @db.Decimal(18, 6)
  units            Decimal?          @db.Decimal(24, 8)
  status           TransactionStatus @default(draft)
  idempotencyKey   String?           @unique @map("idempotency_key")
  requestedAt      DateTime          @default(now()) @map("requested_at") @db.Timestamptz
  paymentConfirmedAt DateTime?       @map("payment_confirmed_at") @db.Timestamptz
  allottedAt       DateTime?         @map("allotted_at") @db.Timestamptz
  cancelledAt      DateTime?         @map("cancelled_at") @db.Timestamptz
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  investmentPlan InvestmentPlan? @relation(fields: [investmentPlanId], references: [id], onDelete: SetNull)
  payments       Payment[]

  @@map("transactions")
}

model Payment {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  transactionId     String?       @map("transaction_id") @db.Uuid
  provider          String
  providerPaymentId String?       @map("provider_payment_id")
  amount            Decimal       @db.Decimal(18, 2)
  currency          String        @default("INR") @db.Char(3)
  mode              String?
  status            PaymentStatus @default(created)
  failureReason     String?       @map("failure_reason")
  idempotencyKey    String?       @unique @map("idempotency_key")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  confirmedAt       DateTime?     @map("confirmed_at") @db.Timestamptz
  reconciledAt      DateTime?     @map("reconciled_at") @db.Timestamptz
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@map("payments")
}


model Mandate {
