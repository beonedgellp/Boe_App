{
  "name": "beonedge-backend-controller",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BeOnEdge HTTP API scaffold and PostgreSQL migration runner.",
  "engines": {
    "node": ">=20"
  },
  "imports": {
    "#router": "./src/router.js",
    "#config/*": "./src/config/*",
    "#db/*": "./src/db/*",
    "#http/*": "./src/http/*",
    "#security/*": "./src/security/*",
    "#shared/*": "./src/shared/*",
    "#client/*": "./src/client/*",
    "#admin/*": "./src/admin/*",
    "#website/*": "./src/website/*"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "db:check": "tsx scripts/check-db.ts",
    "routes": "tsx scripts/print-routes.ts",
    "authz:admin-rbac": "tsx scripts/check-admin-rbac-routes.ts",
    "authz:403": "tsx scripts/check-auth-403-envelope.ts",
    "migrate": "tsx scripts/migrate.ts up",
    "migrate:status": "tsx scripts/migrate.ts status",
    "seed:auth": "tsx scripts/seed-auth.ts"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2"
  }
}
