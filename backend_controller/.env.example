NODE_ENV=development
HOST=127.0.0.1
PORT=47500
LOG_LEVEL=info

# PostgreSQL config. Use either DATABASE_URL or the discrete DATABASE_* vars.
DATABASE_URL=postgres://rahu1kumar:RaHul.123Kum%40R@127.0.0.1:5432/boe_app
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=boe_app
# DATABASE_USER=rahu1kumar
# DATABASE_PASSWORD=RaHul.123Kum@R
DATABASE_SSL=false

# Development data store. Keep DATABASE_URL above for later PostgreSQL switch-over.
DATA_STORE=json
JSON_DB_PATH=./data/dev-db.json

DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=3000
DB_IDLE_TIMEOUT_MS=10000
MIGRATIONS_DIR=./db/migrations

# development, staging, or live
PROVIDER_MODE=development

# Comma-separated origins. Use * only for local isolated development.
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Replace before any shared environment.
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-long-random-secret

# Keeps auth endpoints explicit until the PostgreSQL-backed auth store lands.
ALLOW_DEV_AUTH=false

# Admin login is read directly from env, not from the users table.
ADMIN_LOGIN_ID=admin@beonedge.local
ADMIN_PASSWORD=Admin@123456
ADMIN_FIRST_NAME=BeOnEdge
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=+910000000001

SEED_AUTH_ENABLED=true
SEED_ADMIN_EMAIL=admin@beonedge.local
SEED_ADMIN_PASSWORD=Admin@123456
SEED_CLIENT_EMAIL=client@beonedge.local
SEED_CLIENT_PASSWORD=Client@123456

# Enable mock webhook endpoints for local testing.
# Set to true only in isolated development environments.
MOCK_WEBHOOK_ENABLED=false
