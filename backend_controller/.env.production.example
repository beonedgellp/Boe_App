# BeOnEdge Production Environment Configuration
# Copy this file to .env and fill in all values before deploying.
# NONE of the placeholder values below are safe for production.

NODE_ENV=production
HOST=0.0.0.0
PORT=47500
LOG_LEVEL=warn

# ---------------------------------------------------------------------------
# Database (JSON store for single-node deploy; PostgreSQL for multi-node)
# ---------------------------------------------------------------------------
DB_DRIVER=json
JSON_DB_PATH=./data/dev-db.json

# Uncomment and configure when switching to PostgreSQL:
# DB_DRIVER=pg
# DATABASE_URL=postgres://user:password@host:5432/boe_app
# DATABASE_SSL=true
# DB_POOL_MAX=20
# DB_CONNECTION_TIMEOUT_MS=5000
# DB_IDLE_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Payment Provider (Razorpay TEST mode)
# ---------------------------------------------------------------------------
PROVIDER_MODE=live
RAZORPAY_KEY_ID=rzp_test_SnMqc5CSBmn8Ld
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-your-razorpay-webhook-secret

# ---------------------------------------------------------------------------
# CORS — MUST be explicit domains, never * or localhost in production
# ---------------------------------------------------------------------------
CORS_ORIGIN=https://beonedge.in,https://app.beonedge.in

# ---------------------------------------------------------------------------
# Auth Secrets — Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------
ACCESS_TOKEN_SECRET=replace-with-64-char-random-hex-string
REFRESH_TOKEN_SECRET=replace-with-64-char-random-hex-string

# ---------------------------------------------------------------------------
# Admin Credentials — Change from defaults before first deploy
# ---------------------------------------------------------------------------
ADMIN_LOGIN_ID=admin@beonedge.in
ADMIN_PASSWORD=replace-with-12-char-min-password
ADMIN_FIRST_NAME=BeOnEdge
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=+910000000001

# ---------------------------------------------------------------------------
# Security / Production Hardening
# ---------------------------------------------------------------------------
ALLOW_DEV_AUTH=false
MOCK_WEBHOOK_ENABLED=false

# Seed data is disabled in production. Create admin via direct DB insert or
# admin onboarding flow instead.
SEED_AUTH_ENABLED=false
